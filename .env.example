# ============================================================
# Sellna.ai — Sales Agentic AI
# Free Local Stack: Ollama + sentence-transformers + Qdrant
# ============================================================

# --- App ---
APP_NAME="Sales Agentic AI"
ENVIRONMENT=development
DEBUG=false

# --- Security ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
JWT_EXPIRE_MINUTES=1440

# ============================================================
# LLM — Ollama (local, FREE)
# ============================================================
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3        # pull with: ollama pull llama3
#
# Alternatives (uncomment one):
# OLLAMA_MODEL=llama3.1    # better quality, larger download
# OLLAMA_MODEL=mistral     # fast, good for structured output
# OLLAMA_MODEL=phi3        # very small, good for low-RAM machines
#
# Shared LLM params
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# ============================================================
# EMBEDDINGS — sentence-transformers (local, FREE, runs on CPU)
# ============================================================
EMBEDDING_BACKEND=sentence_transformers
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2   # 384 dims, ~90MB
EMBEDDING_DIMENSION=384

# ============================================================
# VECTOR DB — Qdrant (local Docker, FREE)
# ============================================================
VECTOR_STORE=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=sales_ai_embeddings

# ============================================================
# DATABASE — PostgreSQL
# ============================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sales_ai
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ============================================================
# QUEUE — Redis + Celery
# ============================================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================================
# SCRAPING
# ============================================================
MAX_CONCURRENT_REQUESTS=5
REQUEST_TIMEOUT=30
RETRY_TIMES=3
BROWSER_HEADLESS=true

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
LOG_FORMAT=console       # console | json

# ============================================================
# OBSERVABILITY (disable to skip prometheus dep)
# ============================================================
PROMETHEUS_ENABLED=false
PROMETHEUS_PATH=/metrics

# ============================================================
# PIPELINE
# ============================================================
PIPELINE_TIMEOUT_SECONDS=300

# ============================================================
# CORS
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
